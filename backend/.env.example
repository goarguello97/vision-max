# Database - Connection pooling (for runtime)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (for migrations)
DIRECT_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# JWT
JWT_SECRET=your-256-bit-secret-key-replace-in-production
JWT_EXPIRES_IN=7d

# TMDB API
TMDB_API_KEY=your-tmdb-api-key
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_URL=https://image.tmdb.org/t/p

# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Mock Mode (use mock data instead of real TMDB API)
MOCK_MODE=true